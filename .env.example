TELEGRAM_BOT_TOKEN=
# Tek anahtar veya virgül (veya satır sonu) ile birden fazla (kota/limit yanıtında sıradaki denenir):
# CODEX_API_KEY=jwt_1,jwt_2,jwt_3,jwt_4
CODEX_API_KEY=
# İsteğe bağlı; varsayılan https://graph.codex.io/graphql
# CODEX_GRAPHQL_URL=

# İsteğe bağlı — birden fazla Telegram hesabı aynı listeyi görsün ve uyarı alsın:
# Özel sohbette chat.id = kullanıcı id. Ana hesabı ilk yazın; liste bu chat_id ile DB'de durur.
# TELEGRAM_BOT_USER_IDS=963189208,1313663059,8237599627
# Paylaşımlı depo: genelde ana user id (mevcut watched_tokens.chat_id ile aynı olmalı).
# TELEGRAM_SHARED_STORAGE_ID=963189208
